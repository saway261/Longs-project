# ===== 本番環境用 環境変数サンプル =====
# このファイルをコピーして .env.production を作成し、実際の値を設定してください
# EC2デプロイ時は AWS Secrets Manager などで管理することを推奨

# --- Database (AWS RDS PostgreSQL) ---
# RDSのエンドポイント例: apparel-db.xxxxxxxxxxxx.ap-northeast-1.rds.amazonaws.com
DATABASE_URL="postgresql://dbuser:dbpassword@your-rds-endpoint.ap-northeast-1.rds.amazonaws.com:5432/apparel_db?schema=public&sslmode=require"

# --- AI API ---
GEMINI_API_KEY="your_production_gemini_api_key"

# --- Image Storage (Supabase) ---
IMAGE_STORAGE_TYPE="supabase"
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_production_supabase_service_role_key"
SUPABASE_BUCKET_NAME="design-assets"

# --- Next.js ---
NODE_ENV="production"
PORT=8080

# --- その他（必要に応じて追加） ---
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
