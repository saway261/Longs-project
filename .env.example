DATABASE_URL="postgresql://user:password@localhost:5432/apparel_db"

# 在庫インサイト画面のキャッシュ有効期間（秒）。デフォルト86400（1日）。0で実質無効化。
INSIGHTS_CACHE_TTL_SECONDS=86400
GEMINI_API_KEY="your_gemini_api_key_here"

# 画像ストレージ設定: supabase
IMAGE_STORAGE_TYPE="supabase"

# Supabase 設定（IMAGE_STORAGE_TYPE=supabase の場合に必要）
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sampletext"
SUPABASE_BUCKET_NAME="design-assets"

