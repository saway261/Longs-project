DATABASE_URL="postgresql://user:password@localhost:5432/apparel_db"

# 在庫インサイト画面のキャッシュ有効期間（秒）。デフォルト86400（1日）。0で実質無効化。
INSIGHTS_CACHE_TTL_SECONDS=86400
GEMINI_API_KEY="your_gemini_api_key_here"

# 画像ストレージ設定: supabase
IMAGE_STORAGE_TYPE="supabase"

# Supabase 設定（IMAGE_STORAGE_TYPE=supabase の場合に必要）
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sampletext"
SUPABASE_BUCKET_NAME="design-assets"

NEWSDATA_IO_API_KEY="your_newsdata_io_api_key_here"

# Cron認証トークン（Railway Cron Job / 外部cronからAPIを叩く際に使用）
# ニュース取得: GET /api/cron/fetch-news          → 毎日1回
# LLM分析:     GET /api/cron/run-factor-analysis  → 毎週1回（日曜など週末）
CRON_SECRET="your_cron_secret_here"

# LLM週次分析の実行条件
# "true"（デフォルト）: 週終了後（土曜23:59以降）のみ実行可能
# "false": 週の途中でも5件以上のニュースが収集されていれば実行可能
FACTOR_ANALYSIS_REQUIRE_WEEK_END="true"