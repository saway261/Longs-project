generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enum 定義（6種）
// ============================================================

enum ImportDataset {
  sales
  payables
  receivables
  gross_profit

  @@map("import_dataset")
}

enum ImportStatus {
  processing
  success
  partial
  failed

  @@map("import_status")
}

enum IssueLevel {
  warning
  error

  @@map("issue_level")
}

enum FlowType {
  income
  expense

  @@map("flow_type")
}

enum ProcurementStatus {
  high
  overstock
  normal

  @@map("procurement_status")
}

enum DesignType {
  pop
  poster

  @@map("design_type")
}

enum UserRole {
  admin
  general

  @@map("user_role")
}

// ============================================================
// ユーザー・認証
// ============================================================

model UserAccount {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  name         String?
  passwordHash String?  @map("password_hash")
  role         UserRole @default(general)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  procurementLists ProcurementList[]
  designAssets     DesignAsset[]
  sessions         Session[]

  @@map("user_account")
}

model Session {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  expiresAt      DateTime @map("expires_at") @db.Timestamptz()
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  lastActivityAt DateTime @default(now()) @map("last_activity_at") @db.Timestamptz()

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

// ============================================================
// 設定
// ============================================================

model ProductCategory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @unique
  sellThroughDays Int      @default(60) @map("sell_through_days")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  products Product[]

  @@map("product_category")
}

model ReservePolicy {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  percent     Decimal @db.Decimal(5, 2)
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  @@map("reserve_policy")
}

// ============================================================
// 商品・在庫
// ============================================================

model ProductBrand {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique

  products Product[]

  @@map("product_brand")
}

model Product {
  jan          String   @id
  sku          String?  @unique
  name         String
  categoryId   String?  @map("category_id") @db.Uuid
  brandId      String?  @map("brand_id") @db.Uuid
  season       String?
  manufacturer String?
  status       String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  category ProductCategory? @relation(fields: [categoryId], references: [id])
  brand    ProductBrand?     @relation(fields: [brandId], references: [id])
  variants ProductVariant[]

  @@map("product")
}

model ProductVariant {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productJan String  @map("product_jan")
  variantSku String? @unique @map("variant_sku")
  color      String?
  size       String?
  janCode    String? @map("jan_code")
  priceYen   BigInt? @map("price_yen")

  product          Product           @relation(fields: [productJan], references: [jan])
  inventoryStocks  InventoryStock[]
  procurementItems ProcurementItem[]

  @@map("product_variant")
}

model Warehouse {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String

  inventoryStocks InventoryStock[]

  @@map("warehouse")
}

model InventoryStock {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId   String   @map("variant_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  onHand      Int      @default(0) @map("on_hand")
  reserved    Int      @default(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  variant   ProductVariant @relation(fields: [variantId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])

  @@unique([variantId, warehouseId])
  @@map("inventory_stock")
}

// ============================================================
// 仕入管理
// ============================================================

model ProcurementList {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status    String   @default("draft")
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  creator UserAccount?      @relation(fields: [createdBy], references: [id])
  items   ProcurementItem[]

  @@map("procurement_list")
}

model ProcurementItem {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listId       String            @map("list_id") @db.Uuid
  variantId    String            @map("variant_id") @db.Uuid
  suggestedQty Int?              @map("suggested_qty")
  orderQty     Int?              @map("order_qty")
  priceYen     BigInt?           @map("price_yen")
  status       ProcurementStatus @default(normal)
  addedAt      DateTime          @default(now()) @map("added_at") @db.Timestamptz()

  list    ProcurementList @relation(fields: [listId], references: [id], onDelete: Cascade)
  variant ProductVariant  @relation(fields: [variantId], references: [id])

  @@map("procurement_item")
}

// ============================================================
// 在庫計画
// ============================================================

model InventoryPlanYear {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fiscalYear Int      @unique @map("fiscal_year")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  months InventoryPlanMonth[]

  @@map("inventory_plan_year")
}

model InventoryPlanMonth {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planYearId              String   @map("plan_year_id") @db.Uuid
  monthDate               DateTime @map("month_date") @db.Date
  purchaseBudgetYen       BigInt?  @map("purchase_budget_yen")
  shipmentAmountYen       BigInt?  @map("shipment_amount_yen")
  shipmentGrossProfitRate Decimal? @map("shipment_gross_profit_rate") @db.Decimal(5, 2)
  shipmentCostYen         BigInt?  @map("shipment_cost_yen")
  wasteYen                BigInt?  @map("waste_yen")
  monthEndInventoryYen    BigInt?  @map("month_end_inventory_yen")
  inventoryPlanYen        BigInt?  @map("inventory_plan_yen")

  planYear InventoryPlanYear @relation(fields: [planYearId], references: [id], onDelete: Cascade)

  @@unique([planYearId, monthDate])
  @@map("inventory_plan_month")
}

// ============================================================
// 財務管理
// ============================================================

model Counterparty {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String
  type String @default("other")

  financeSchedules FinanceSchedule[]

  @@map("counterparty")
}

model FinanceSchedule {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  counterpartyId String?   @map("counterparty_id") @db.Uuid
  description    String?
  amountYen      BigInt    @map("amount_yen")
  flow           FlowType
  category       String
  cycle          String?
  offsetMonths   Int       @default(0) @map("offset_months")
  dueDay         Int       @map("due_day")
  seasonality    Decimal[] @db.Decimal
  isFixed        Boolean   @default(false) @map("is_fixed")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  counterparty Counterparty?           @relation(fields: [counterpartyId], references: [id])
  events       FinanceEvent[]
  tagMaps      FinanceScheduleTagMap[]

  @@index([counterpartyId])
  @@map("finance_schedule")
}

model FinanceScheduleTag {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique

  tagMaps FinanceScheduleTagMap[]

  @@map("finance_schedule_tag")
}

model FinanceScheduleTagMap {
  scheduleId String @map("schedule_id") @db.Uuid
  tagId      String @map("tag_id") @db.Uuid

  schedule FinanceSchedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  tag      FinanceScheduleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([scheduleId, tagId])
  @@map("finance_schedule_tag_map")
}

model FinanceEvent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId   String?   @map("schedule_id") @db.Uuid
  dueDate      DateTime  @map("due_date") @db.Date
  amountYen    BigInt    @map("amount_yen")
  flow         FlowType
  category     String?
  status       String    @default("planned")
  actualPaidAt DateTime? @map("actual_paid_at") @db.Date
  note         String?

  schedule FinanceSchedule? @relation(fields: [scheduleId], references: [id])

  @@index([dueDate])
  @@map("finance_event")
}

// ============================================================
// データインポート
// ============================================================

model DataImport {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dataset       ImportDataset
  fileName      String?       @map("file_name")
  status        ImportStatus  @default(processing)
  summary       String?
  note          String?
  importedAt    DateTime      @default(now()) @map("imported_at") @db.Timestamptz()
  rowsTotal     Int?          @map("rows_total")
  rowsSuccess   Int?          @map("rows_success")
  rowsSkipped   Int?          @map("rows_skipped")
  warningsCount Int?          @map("warnings_count")
  errorsCount   Int?          @map("errors_count")

  rows             DataImportRow[]
  issues           DataImportIssue[]
  salesFacts       SalesFact[]
  payablesFacts    PayablesFact[]
  receivablesFacts ReceivablesFact[]
  grossProfitFacts GrossProfitFact[]

  @@index([dataset, importedAt(sort: Desc)])
  @@map("data_import")
}

model DataImportRow {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importId  String @map("import_id") @db.Uuid
  rowNumber Int    @map("row_number")
  rawData   Json   @map("raw_data")

  import DataImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@map("data_import_row")
}

model DataImportIssue {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importId   String     @map("import_id") @db.Uuid
  level      IssueLevel
  message    String
  rowNumber  Int?       @map("row_number")
  columnName String?    @map("column_name")

  import DataImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@map("data_import_issue")
}

// ============================================================
// ファクト表（正規化データ）
// ============================================================

model SalesFact {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importId              String?   @map("import_id") @db.Uuid
  customerCategory1Code String?   @map("customer_category1_code")
  customerCategory1Name String?   @map("customer_category1_name")
  brandCode             String?   @map("brand_code")
  brandName             String?   @map("brand_name")
  itemCode              String?   @map("item_code")
  itemName              String?   @map("item_name")
  productCode           String?   @map("product_code")
  productName1          String?   @map("product_name1")
  productName2          String?   @map("product_name2")
  cs1Code               String?   @map("cs1_code")
  cs1Name               String?   @map("cs1_name")
  cs2Code               String?   @map("cs2_code")
  cs2Name               String?   @map("cs2_name")
  staffCode             String?   @map("staff_code")
  staffName             String?   @map("staff_name")
  periodYm              DateTime? @map("period_ym") @db.Date
  salesDate             DateTime? @map("sales_date") @db.Date
  janCode               String?   @map("jan_code")
  netQty                Int?      @map("net_qty")
  listPriceYen          BigInt?   @map("list_price_yen")
  netSalesYen           BigInt?   @map("net_sales_yen")
  returnYen             BigInt?   @map("return_yen")
  grossProfitYen        BigInt?   @map("gross_profit_yen")
  grossProfitRate       Decimal?  @map("gross_profit_rate") @db.Decimal(5, 2)

  import DataImport? @relation(fields: [importId], references: [id])

  @@index([periodYm])
  @@map("sales_fact")
}

model PayablesFact {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importId           String? @map("import_id") @db.Uuid
  vendorName         String? @map("vendor_name")
  vendorShort        String? @map("vendor_short")
  prevBalanceYen     BigInt? @map("prev_balance_yen")
  paymentYen         BigInt? @map("payment_yen")
  carryoverYen       BigInt? @map("carryover_yen")
  netPurchaseYen     BigInt? @map("net_purchase_yen")
  purchaseYen        BigInt? @map("purchase_yen")
  returnYen          BigInt? @map("return_yen")
  discountYen        BigInt? @map("discount_yen")
  otherYen           BigInt? @map("other_yen")
  taxYen             BigInt? @map("tax_yen")
  purchaseTaxInYen   BigInt? @map("purchase_tax_in_yen")
  monthEndBalanceYen BigInt? @map("month_end_balance_yen")
  cashYen            BigInt? @map("cash_yen")
  checkYen           BigInt? @map("check_yen")
  transferYen        BigInt? @map("transfer_yen")
  billYen            BigInt? @map("bill_yen")
  offsetYen          BigInt? @map("offset_yen")
  discount2Yen       BigInt? @map("discount2_yen")
  feeYen             BigInt? @map("fee_yen")
  other2Yen          BigInt? @map("other2_yen")

  import DataImport? @relation(fields: [importId], references: [id])

  @@map("payables_fact")
}

model ReceivablesFact {
  id                    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importId              String? @map("import_id") @db.Uuid
  staffName             String? @map("staff_name")
  customerName          String? @map("customer_name")
  customerShort         String? @map("customer_short")
  prevBalanceYen        BigInt? @map("prev_balance_yen")
  receivedYen           BigInt? @map("received_yen")
  carryoverYen          BigInt? @map("carryover_yen")
  netSalesYen           BigInt? @map("net_sales_yen")
  salesYen              BigInt? @map("sales_yen")
  returnYen             BigInt? @map("return_yen")
  discountYen           BigInt? @map("discount_yen")
  otherYen              BigInt? @map("other_yen")
  taxYen                BigInt? @map("tax_yen")
  salesTaxInYen         BigInt? @map("sales_tax_in_yen")
  monthEndBalanceYen    BigInt? @map("month_end_balance_yen")
  cashYen               BigInt? @map("cash_yen")
  checkYen              BigInt? @map("check_yen")
  transferYen           BigInt? @map("transfer_yen")
  billYen               BigInt? @map("bill_yen")
  offsetYen             BigInt? @map("offset_yen")
  discount2Yen          BigInt? @map("discount2_yen")
  feeYen                BigInt? @map("fee_yen")
  other2Yen             BigInt? @map("other2_yen")
  npCreditYen           BigInt? @map("np_credit_yen")
  npPaymentsYen         BigInt? @map("np_payments_yen")
  creditLimitBalanceYen BigInt? @map("credit_limit_balance_yen")
  notes                 String?

  import DataImport? @relation(fields: [importId], references: [id])

  @@index([customerName])
  @@map("receivables_fact")
}

model GrossProfitFact {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importId              String?  @map("import_id") @db.Uuid
  staffName             String?  @map("staff_name")
  fiscalYear            Int?     @map("fiscal_year")
  customerCategory1Code String?  @map("customer_category1_code")
  customerCategory1Name String?  @map("customer_category1_name")
  netQty                Int?     @map("net_qty")
  listPriceYen          BigInt?  @map("list_price_yen")
  netSalesYen           BigInt?  @map("net_sales_yen")
  returnYen             BigInt?  @map("return_yen")
  grossProfitYen        BigInt?  @map("gross_profit_yen")
  grossProfitRate       Decimal? @map("gross_profit_rate") @db.Decimal(5, 2)

  import DataImport? @relation(fields: [importId], references: [id])

  @@map("gross_profit_fact")
}

// ============================================================
// デザイン・AI
// ============================================================

model DesignAsset {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      DesignType
  title     String?
  prompt    String?
  style     String?
  color     String?
  ratio     String?
  imageUrl  String?    @map("image_url")
  createdBy String?    @map("created_by") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  deletedAt DateTime?  @map("deleted_at") @db.Timestamptz()

  creator UserAccount? @relation(fields: [createdBy], references: [id])
  aiLogs  AiGenerationLog[]

  @@map("design_asset")
}

model AiGenerationLog {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  designAssetId    String   @map("design_asset_id") @db.Uuid
  model            String
  promptTokens     Int      @map("prompt_tokens")
  candidatesTokens Int      @map("candidates_tokens")
  totalTokens      Int      @map("total_tokens")
  responseTimeMs   Int?     @map("response_time_ms")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  designAsset DesignAsset @relation(fields: [designAssetId], references: [id], onDelete: Cascade)

  @@index([designAssetId])
  @@map("ai_generation_log")
}

model AiInsight {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      String
  title     String?
  summary   String?
  severity  String?
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("ai_insight")
}
